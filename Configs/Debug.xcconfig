// Debug.xcconfig
// Still Hours — Debug build settings
//
// Purpose: per-configuration build settings separated from project.yml.
//
// Team ID 89J24XNYL3 is set here directly — Apple Team IDs are public
// identifiers (visible in any signed binary), not secrets. Bundle ID
// was registered 2026-05-21 via ASC API; same OYL Apple Developer Team.
// For a different developer to build this repo locally, override via
// Configs/Local.xcconfig (gitignored).

DEVELOPMENT_TEAM = 89J24XNYL3
CODE_SIGN_STYLE = Automatic
PROVISIONING_PROFILE_SPECIFIER =
CODE_SIGN_IDENTITY = Apple Development
CODE_SIGN_ENTITLEMENTS = App/Resources/StillHours.entitlements

SWIFT_OPTIMIZATION_LEVEL = -Onone
SWIFT_COMPILATION_MODE = singlefile
GCC_OPTIMIZATION_LEVEL = 0
ENABLE_TESTABILITY = YES
ENABLE_DEBUG_DYLIB_OVERRIDE = YES
