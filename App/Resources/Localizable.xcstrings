{
  "sourceLanguage": "ko",
  "version": "1.0",
  "strings": {
    "about.collapse": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "두 번 탭하여 접기"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Double-tap to collapse"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダブルタップして折りたたむ"
          }
        }
      }
    },
    "about.expand": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "두 번 탭하여 펼치기"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Double-tap to expand"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダブルタップして展開する"
          }
        }
      }
    },
    "about.section.dataSovereignty": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데이터 주권"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Data Sovereignty"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データ主権"
          }
        }
      }
    },
    "about.section.dataSovereignty.body": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데이터는 당신의 iCloud에만 존재합니다. JSON 또는 CSV로 언제든 내보낼 수 있으며, 앱을 삭제하면 데이터도 삭제됩니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your data lives in your iCloud only. Export as JSON or CSV at any time. Delete the app and the data goes with it."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データはあなたのiCloudのみに存在します。いつでもJSONまたはCSVでエクスポートできます。アプリを削除するとデータも削除されます。"
          }
        }
      }
    },
    "about.section.identity": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Still Hours는"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Still Hours is"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Still Hoursとは"
          }
        }
      }
    },
    "about.section.identity.body": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "알고리즘 없음 · 공개 피드 없음 · 광고 없음.\n\n조용한 수집 도구입니다. 당신이 가진 것의 이야기를 기록합니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No algorithm · No public feed · No advertising.\n\nA quiet collection tool. Records the story of what you have."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アルゴリズムなし · 公開フィードなし · 広告なし。\n\n静かなコレクションツール。あなたが持つものの物語を記録します。"
          }
        }
      }
    },
    "about.section.madeBy": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "만든 사람"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Made by"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作成者"
          }
        }
      }
    },
    "about.section.madeBy.body": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "sunghun.ahn이 혼자 만든 도구입니다. 10년을 쓸 수 있도록 만들었습니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A solo tool by sunghun.ahn. Built to last ten years."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "sunghun.ahnが一人で作ったツールです。10年使えるように設計しました。"
          }
        }
      }
    },
    "accessibility.onboarding.1.card": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Book cover: Norwegian Wood. Your items become the entry to memories."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブックカバー：ノルウェイの森。アイテムが記憶への入口になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "책 표지: 노르웨이의 숲. 아이템이 기억의 입구가 됩니다."
          }
        }
      }
    },
    "accessibility.onboarding.1.memory": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Memory entry: Tokyo Tsutaya, August 2024, with my mother"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記憶エントリー：東京 蔦屋書店、2024年8月、母と一緒に"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기억 항목: 도쿄 츠타야, 2024년 8월, 엄마와 함께"
          }
        }
      }
    },
    "accessibility.onboarding.3.sheet": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Share to: friend Minjin. No public profile. No social media sharing."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "共有先：友人ミンジン。公開プロフィールなし。SNSシェアなし。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "공유 대상: 친구 민진. 공개 프로필 없음. SNS 공유 없음."
          }
        }
      }
    },
    "app.name": {
      "extractionState": "manual",
