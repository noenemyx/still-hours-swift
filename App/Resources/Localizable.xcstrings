      }
    },
    "about.section.identity.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "알고리즘 없음 · 공개 피드 없음 · 광고 없음.\n\n조용한 수집 도구입니다. 당신이 가진 것의 이야기를 기록합니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No algorithm · No public feed · No advertising.\n\nA quiet collection tool. Records the story of what you have." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "アルゴリズムなし · 公開フィードなし · 広告なし。\n\n静かなコレクションツール。あなたが持つものの物語を記録します。" } }
      }
    },
    "about.section.dataSovereignty" : {
      "extractionState" : "manual",
