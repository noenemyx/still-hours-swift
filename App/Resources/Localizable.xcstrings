    "privacy.section.onDevice.body": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 데이터는 사용자의 기기와 개인 iCloud 계정에만 저장됩니다. Still Hours 서버는 존재하지 않습니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All data is stored only on your device and your personal iCloud account. There is no Still Hours server."
