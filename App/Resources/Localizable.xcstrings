          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These commitments are declared in code via the PrivacyInfo.xcprivacy manifest, visible on the Apple App Store."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これらの約束はPrivacyInfo.xcprivacyマニフェストでコードとして宣言されており、Apple App Storeで確認できます。"
          }
        }
      }
    },
    "privacy.section.cloudkit.body": {
      "extractionState": "manual",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동기화는 Apple CloudKit Private Database를 통해서만 이루어집니다. 개발자는 사용자의 데이터에 접근할 수 없습니다."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sync happens only through Apple CloudKit Private Database. The developer cannot access your data."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期はApple CloudKit Private Databaseのみを通じて行われます。開発者はあなたのデータにアクセスできません。"
          }
        }
      }
    },
