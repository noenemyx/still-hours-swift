        "ko" : { "stringUnit" : { "state" : "translated", "value" : "데이터 주권" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Data Sovereignty" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "データ主権" } }
      }
    },
    "about.section.dataSovereignty.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "데이터는 당신의 iCloud에만 존재합니다. JSON 또는 CSV로 언제든 내보낼 수 있으며, 앱을 삭제하면 데이터도 삭제됩니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your data lives in your iCloud only. Export as JSON or CSV at any time. Delete the app and the data goes with it." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "データはあなたのiCloudのみに存在します。いつでもJSONまたはCSVでエクスポートできます。アプリを削除するとデータも削除されます。" } }
      }
    },
    "about.section.madeBy" : {
      "extractionState" : "manual",
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "만든 사람" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Made by" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "作成者" } }
      }
    },
    "about.section.madeBy.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "sunghun.ahn이 혼자 만든 도구입니다. 10년을 쓸 수 있도록 만들었습니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A solo tool by sunghun.ahn. Built to last ten years." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "sunghun.ahnが一人で作ったツールです。10年使えるように設計しました。" } }
      }
    },
    "privacy.manifest.footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "PrivacyInfo.xcprivacy manifest를 통해 Apple App Store에 위 약속이 코드로 선언되어 있습니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "These commitments are declared in code via the PrivacyInfo.xcprivacy manifest, visible on the Apple App Store." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "これらの約束はPrivacyInfo.xcprivacyマニフェストでコードとして宣言されており、Apple App Storeで確認できます。" } }
      }
    },
    "privacy.section.onDevice.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "모든 데이터는 사용자의 기기와 개인 iCloud 계정에만 저장됩니다. Still Hours 서버는 존재하지 않습니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "All data is stored only on your device and your personal iCloud account. There is no Still Hours server." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "すべてのデータはあなたのデバイスと個人のiCloudアカウントにのみ保存されます。Still Hoursのサーバーは存在しません。" } }
      }
    },
    "privacy.section.cloudkit.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "동기화는 Apple CloudKit Private Database를 통해서만 이루어집니다. 개발자는 사용자의 데이터에 접근할 수 없습니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Sync happens only through Apple CloudKit Private Database. The developer cannot access your data." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "同期はApple CloudKit Private Databaseのみを通じて行われます。開発者はあなたのデータにアクセスできません。" } }
      }
    },
    "privacy.section.noAds.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "분석 SDK 없음, 광고 네트워크 없음, 제3자 데이터 판매 없음. PrivacyInfo.xcprivacy에 이 약속이 코드로 선언되어 있습니다." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No analytics SDK, no ad network, no third-party data sale. This commitment is declared in code in PrivacyInfo.xcprivacy." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "分析SDKなし、広告ネットワークなし、第三者へのデータ販売なし。この約束はPrivacyInfo.xcprivacyでコードとして宣言されています。" } }
      }
    }
  }
